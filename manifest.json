{
  "manifest_version": 3,
  "name": "VibeBhasha",
  "version": "1.0.0",
  "description": "Speak prompts in your native language for Lovable.dev - supports 18 languages including Hindi, Spanish, German, Mandarin, and more",
  "author": "Lovable Voice Helper",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "offscreen",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://*.lovable.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lovable.dev/*",
        "https://*.lovable.dev/*"
      ],
      "js": ["content-script.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Lovable Voice Helper"
  },
  "options_page": "options.html",
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Start/Stop voice recording"
    }
  },
  "oauth2": {
    "client_id": "640786701240-l4snupbrthi44o0431a94b3gjvao390m.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*"],
      "matches": ["https://lovable.dev/*", "https://*.lovable.dev/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
